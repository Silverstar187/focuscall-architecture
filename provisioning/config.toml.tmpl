# focuscall.ai — ZeroClaw config template
# Variables replaced by provision.py: $USER_ID $AGENT_ID $PORT $LLM_PROVIDER
#
# SECURITY: Keys are NEVER written here.
# ZeroClaw reads them from ENV vars automatically:
#   ZEROCLAW_API_KEY      — overrides api_key
#   TELEGRAM_BOT_TOKEN    — injected into channels_config.telegram.bot_token
#
# Schema source: zeroclaw config schema (v0.6.7)

# ── Provider ───────────────────────────────────────────────────────────────────
default_provider = "$LLM_PROVIDER"   # openrouter | anthropic | openai | ollama
# api_key: read from ENV ZEROCLAW_API_KEY — not written here

default_model = "openai/gpt-4o-mini"   # Override per agent if needed

# ── Gateway ────────────────────────────────────────────────────────────────────
[gateway]
host                   = "127.0.0.1"
port                   = $PORT
require_pairing        = false          # Disabled — Telegram bot_token is the auth
session_persistence    = true

# ── Telegram Channel ───────────────────────────────────────────────────────────
[channels_config.telegram]
# bot_token: injected at runtime via TELEGRAM_BOT_TOKEN env var in provision.py
bot_token     = "${TELEGRAM_BOT_TOKEN}"   # ZeroClaw reads this from ENV at startup
allowed_users = []                        # Empty = allow all (pairing handles auth)
stream_mode   = "multi_message"           # off | partial | multi_message

# ── Autonomy ───────────────────────────────────────────────────────────────────
[autonomy]
level = "supervised"   # readonly | supervised | full

# ── Shell Tool ─────────────────────────────────────────────────────────────────
[shell_tool]
# Disabled via autonomy — no explicit disable key needed in v0.6.7

# ── Agent ──────────────────────────────────────────────────────────────────────
[agent]
max_history_messages  = 50
max_context_tokens    = 32000
max_tool_iterations   = 10

# ── Storage ────────────────────────────────────────────────────────────────────
[storage]
# Workspace is mounted at /workspace — ZeroClaw writes db, logs here automatically

# ── Cost Guard ─────────────────────────────────────────────────────────────────
[cost]
# Prevent runaway costs per agent
# Uncomment and adjust as needed:
# daily_limit_usd = 1.0
# per_message_limit_usd = 0.05
